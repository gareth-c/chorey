PORT=5152

# Change this to a long random string in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me-in-production

# WebAuthn (passkey) settings. Passkeys only work in a "secure context":
# https on a real domain, or http://localhost. If you access this app over a
# plain http://<lan-ip>:5152 URL (e.g. a shared tablet on your home network),
# the passkey option will be unusable there — the Child Portal's "Parent
# sign-in" picker still supports password login as a fallback.
RP_ID=localhost
RP_NAME=Chorey
ORIGIN=http://localhost:5152
