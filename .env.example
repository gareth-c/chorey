PORT=5152

# Change this to a long random string in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET=change-me-in-production

# Number of reverse-proxy hops in front of the app (Express "trust proxy").
# The typical production setup — Caddy/Traefik/Nginx terminating HTTPS in
# front of the container — is exactly 1 hop, which is the default. Set 0 only
# if browsers connect straight to the Node process with no proxy.
TRUST_PROXY=1

# WebAuthn (passkey) settings. Passkeys only work in a "secure context":
# https on a real domain, or http://localhost. Over a plain
# http://<lan-ip>:5152 URL (e.g. a shared tablet on your home network), the
# Child Portal's "Parent sign-in" picker — which is passkey-only — will be
# unusable; sign in from /login on that device instead.
RP_ID=localhost
RP_NAME=Chorey
ORIGIN=http://localhost:5152
